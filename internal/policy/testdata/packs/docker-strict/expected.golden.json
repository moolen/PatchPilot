{
  "version": 1,
  "excluded_cves": null,
  "excluded_vulnerabilities": null,
  "scan_skip_paths": null,
  "registry_cache_dir": "",
  "registry_cache_ttl": "",
  "registry_auth_mode": "auto",
  "registry_auth_token_env": "",
  "oci_policies": [
    {
      "Name": "strict",
      "Source": "ghcr.io/example/*",
      "Tags": {
        "Allow": [
          "^v?\\d+\\.\\d+\\.\\d+$"
        ],
        "Semver": [
          {
            "Range": [
              "\u003e=1.2.3 \u003c2.0.0"
            ],
            "IncludePrerelease": false,
            "PrereleaseAllow": [
              "-rc\\."
            ]
          }
        ],
        "Deny": [
          "-debug$"
        ]
      }
    }
  ],
  "oci_external_images": null
}
