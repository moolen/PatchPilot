{
  "version": 1,
  "verification_mode": "append",
  "verification_commands": [
    {
      "Name": "lint",
      "Run": "make lint",
      "Timeout": "4m"
    }
  ],
  "post_execution_hooks": [
    {
      "Name": "cleanup",
      "Run": "rm -rf .tmp-work",
      "When": "always",
      "FailOnError": false
    }
  ],
  "excluded_cves": [
    "CVE-2025-12345"
  ],
  "excluded_vulnerabilities": [
    {
      "ID": "GHSA-xxxx-yyyy-zzzz",
      "Package": "openssl",
      "Ecosystem": "deb",
      "Path": "images/Dockerfile",
      "Reason": "",
      "Owner": "",
      "ExpiresAt": ""
    }
  ],
  "scan_skip_paths": [
    "examples/legacy/**",
    "vendor/**"
  ],
  "registry_cache_dir": ".patchpilot-cache/registry",
  "registry_cache_ttl": "4h",
  "registry_auth_mode": "none",
  "registry_auth_token_env": "",
  "oci_policies": [
    {
      "Name": "stable-golang",
      "Source": "docker.io/library/golang",
      "Tags": {
        "Allow": [
          "^v?\\d+\\.\\d+\\.\\d+-alpine$"
        ],
        "Semver": [
          {
            "Range": [
              "\u003e=1.24.3 \u003c2.0.0"
            ],
            "IncludePrerelease": false,
            "PrereleaseAllow": null
          }
        ],
        "Deny": [
          ".*-debug$"
        ]
      }
    }
  ],
  "oci_external_images": [
    {
      "Source": "ghcr.io/external-secrets/external-secrets",
      "Dockerfiles": [
        "images/Dockerfile"
      ],
      "Tag": "latest-semver"
    }
  ]
}
